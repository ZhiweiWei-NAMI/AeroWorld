{
  "$schema": "event_script_v1",
  "scenario_id": "L2-3_v2",
  "description": "Charger unavailable with reroute to backup charger",
  "parameters": {
    "failure_tick": 260,
    "resolution_tick": 520
  },
  "triggers": [
    {
      "trigger_id": "trig_charger_unavailable",
      "type": "tick",
      "tick": 240
    },
    {
      "trigger_id": "trig_after_charger_unavailable_delay_30",
      "type": "event_fired_after",
      "event_id": "charger_unavailable",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_uav_inspects_charger_delay_30",
      "type": "event_fired_after",
      "event_id": "uav_inspects_charger",
      "delay_ticks": 30
    }
  ],
  "events": [
    {
      "event_id": "charger_unavailable",
      "trigger_ref": "trig_charger_unavailable",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_primary_charger_offline",
          "entity_id": "charger_primary_l2_3_v2",
          "visual_state": {
            "mode": "unavailable"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L2-3_v2_charger_unavailable",
        "category": "infrastructure",
        "title": "Primary charger becomes unavailable",
        "severity": "warning",
        "overlay": "infrastructure",
        "target_ids": [
          "charger_primary_l2_3_v2"
        ]
      }
    },
    {
      "event_id": "uav_inspects_charger",
      "trigger_ref": "trig_after_charger_unavailable_delay_30",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_charger_inspection",
          "entity_id": "uav_l2_3_v2",
          "waypoints_enu_m": [
            [
              7077.0,
              6217.5,
              28
            ],
            [
              7083.0,
              6212.5,
              18
            ],
            [
              7086.0,
              6210.5,
              10
            ]
          ],
          "velocity_mps": 4.0
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_charger_fault",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L2-3_v2_uav_inspects_charger",
        "category": "uav_mission",
        "title": "UAV checks the unavailable charger",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_l2_3_v2",
          "charger_primary_l2_3_v2"
        ]
      }
    },
    {
      "event_id": "reroute_backup_charger",
      "trigger_ref": "trig_after_uav_inspects_charger_delay_30",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_backup_charger",
          "entity_id": "uav_l2_3_v2",
          "waypoints_enu_m": [
            [
              7086.0,
              6210.5,
              10
            ],
            [
              7097.0,
              6215.5,
              18
            ],
            [
              7108.0,
              6219.5,
              10
            ]
          ],
          "velocity_mps": 6.0
        },
        {
          "type": "set_visual_state",
          "action_id": "set_backup_charger_reserved",
          "entity_id": "charger_backup_l2_3_v2",
          "visual_state": {
            "mode": "reserved"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L2-3_v2_reroute_backup_charger",
        "category": "uav_mission",
        "title": "UAV reroutes to backup charger",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_l2_3_v2",
          "charger_backup_l2_3_v2"
        ]
      }
    }
  ]
}
