          "motion_policy": "inspect_orbit_or_racetrack_not_static_hover"
        },
        "required_event": "charger unavailable > backup landing",
        "background_semantics": {
          "vehicle_role": "facility access traffic",
          "pedestrian_role": "pedestrians near charging area",
          "policy": "semantic_context_not_decoration"
        },
        "weather": "clear",
        "determinism": {
          "fallback": "forbidden",
          "guessing": "forbidden",
          "compatibility_paths": "forbidden"
        }
      },
      "description": "Episode must match the low-altitude semantic event-chain contract exactly after generation"
    },
