      "contract": {
        "schema": "low_altitude_event_chain_contract_v1",
        "scenario_id": "L2-3_v1",
        "exact_counts": {
          "uav": 3,
          "vehicle": 2,
          "pedestrian": 2,
          "facility": 3,
          "logical": 6
        },
