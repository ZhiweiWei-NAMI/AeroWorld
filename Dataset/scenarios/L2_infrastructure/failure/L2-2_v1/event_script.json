{
  "$schema": "event_script_v1",
  "scenario_id": "L2-2_v1",
  "description": "GNSS urban canyon multipath drift and visual correction",
  "parameters": {
    "failure_tick": 260,
    "resolution_tick": 520
  },
  "triggers": [
    {
      "trigger_id": "trig_gnss_anomaly",
      "type": "tick",
      "tick": 250
    },
    {
      "trigger_id": "trig_after_gnss_anomaly",
      "type": "event_fired",
      "event_id": "gnss_anomaly"
    },
    {
      "trigger_id": "trig_visual_relocalization",
      "type": "entity_proximity",
      "entity_a": "uav_l2_2_v1",
      "entity_b": "facade_l2_2_v1",
      "distance_m": 8.0,
      "operator": "lte",
      "min_true_ticks": 3
    },
    {
      "trigger_id": "trig_after_visual_relocalization",
      "type": "event_fired",
      "event_id": "visual_relocalization"
    }
  ],
  "events": [
    {
      "event_id": "gnss_anomaly",
      "trigger_ref": "trig_gnss_anomaly",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_tower_multipath",
          "entity_id": "tower_l2_2_v1",
          "visual_state": {
            "mode": "multipath_warning"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L2-2_v1_gnss_anomaly",
        "category": "digital_layer",
        "title": "GNSS multipath anomaly in urban canyon",
        "severity": "warning",
        "overlay": "digital_layer",
        "target_ids": [
          "uav_l2_2_v1",
          "tower_l2_2_v1"
        ]
      }
    },
    {
      "event_id": "route_drift",
      "trigger_ref": "trig_after_gnss_anomaly",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_multipath_drift",
          "entity_id": "uav_l2_2_v1",
          "waypoints_enu_m": [
            [
              62.0,
              -7.0,
              30
            ],
            [
              76.0,
              -3.0,
              28
            ],
            [
              90.0,
              7.0,
              24
            ]
          ],
          "velocity_mps": 6.0
        }
      ],
      "log_event": {
        "topic": "evt_L2-2_v1_route_drift",
        "category": "uav_mission",
        "title": "UAV drifts off planned route by more than 10m",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_l2_2_v1",
          "facade_l2_2_v1"
        ]
      }
    },
    {
      "event_id": "visual_relocalization",
      "trigger_ref": "trig_visual_relocalization",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_uav_visual_reloc",
          "entity_id": "uav_l2_2_v1",
          "visual_state": {
            "mode": "visual_relocalization"
          }
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_gnss_drift",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L2-2_v1_visual_relocalization",
        "category": "uav_mission",
        "title": "Visual relocalization engages near facade",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_l2_2_v1",
          "facade_l2_2_v1"
        ]
      }
    },
    {
      "event_id": "route_corrected",
      "trigger_ref": "trig_after_visual_relocalization",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_corrected_route",
          "entity_id": "uav_l2_2_v1",
          "waypoints_enu_m": [
            [
              90.0,
              7.0,
              24
            ],
            [
              80.0,
              13.0,
              30
            ]
          ],
          "velocity_mps": 5.0
        }
      ],
      "log_event": {
        "topic": "evt_L2-2_v1_route_corrected",
        "category": "uav_mission",
        "title": "UAV corrects the route after visual relocalization",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_l2_2_v1"
        ]
      }
    }
  ]
}
