{
  "$schema": "event_script_v1",
  "scenario_id": "L2-2_v2",
  "description": "Sudden GNSS denial (urban interference)",
  "parameters": {
    "failure_tick": 400
  },
  "triggers": [
    {
      "trigger_id": "trig_infra_failure",
      "type": "tick",
      "tick": 400
    },
    {
      "trigger_id": "trig_after_infra_failure",
      "type": "event_fired",
      "event_id": "infra_failure"
    }
  ],
  "events": [
    {
      "event_id": "infra_failure",
      "trigger_ref": "trig_infra_failure",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "vis_004",
          "entity_id": "infra_station_01",
          "visual_state": {
            "mode": "disabled"
          }
        }
      ],
      "on_fire": {
        "emit_events": [
          "service_degraded"
        ]
      },
      "log_event": {
        "topic": "evt_L2-2_v2_failure",
        "category": "infrastructure",
        "title": "Sudden GNSS denial (urban interference) — 基础设施故障",
        "severity": "warning",
        "overlay": "infrastructure",
        "target_ids": [
          "infra_station_01"
        ]
      }
    },
    {
      "event_id": "service_degraded",
      "trigger_ref": "trig_after_infra_failure",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_018",
          "entity_id": "uav_ops_01",
          "waypoints_enu_m": [
            [
              50,
              20,
              30
            ],
            [
              48,
              22,
              20
            ]
          ],
          "velocity_mps": 4.0
        }
      ],
      "log_event": {
        "topic": "evt_L2-2_v2_degraded",
        "category": "uav_mission",
        "title": "服务降级 — UAV 调整运行模式",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_ops_01"
        ]
      }
    }
  ]
}