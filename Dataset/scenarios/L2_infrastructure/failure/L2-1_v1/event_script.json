{
  "$schema": "event_script_v1",
  "scenario_id": "L2-1_v1",
  "description": "Communication station failure with backup link recovery",
  "parameters": {
    "failure_tick": 260,
    "resolution_tick": 520
  },
  "triggers": [
    {
      "trigger_id": "trig_station_degraded",
      "type": "tick",
      "tick": 260
    },
    {
      "trigger_id": "trig_after_station_degraded_delay_30",
      "type": "event_fired_after",
      "event_id": "station_degraded",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_uav_link_response_delay_59",
      "type": "event_fired_after",
      "event_id": "uav_link_response",
      "delay_ticks": 59
    }
  ],
  "events": [
    {
      "event_id": "station_degraded",
      "trigger_ref": "trig_station_degraded",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_tower_degraded",
          "entity_id": "tower_l2_1_v1",
          "visual_state": {
            "mode": "degraded"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L2-1_v1_station_degraded",
        "category": "infrastructure",
        "title": "Communication station degraded",
        "severity": "warning",
        "overlay": "infrastructure",
        "target_ids": [
          "tower_l2_1_v1"
        ]
      }
    },
    {
      "event_id": "uav_link_response",
      "trigger_ref": "trig_after_station_degraded_delay_30",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_backup_loiter",
          "entity_id": "uav_l2_1_v1",
          "waypoints_enu_m": [
            [
              7048.0,
              6182.0,
              31
            ],
            [
              7058.0,
              6192.0,
              30
            ],
            [
              7061.0,
              6197.0,
              34
            ]
          ],
          "velocity_mps": 4.0
        }
      ],
      "log_event": {
        "topic": "evt_L2-1_v1_uav_link_response",
        "category": "uav_mission",
        "title": "UAV changes behavior under degraded C2",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_l2_1_v1",
          "tower_l2_1_v1"
        ]
      }
    },
    {
      "event_id": "backup_link_restore",
      "trigger_ref": "trig_after_uav_link_response_delay_59",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_tower_backup",
          "entity_id": "tower_l2_1_v1",
          "visual_state": {
            "mode": "backup_link"
          }
        },
        {
          "type": "move_entity",
          "action_id": "move_uav_resume_patrol",
          "entity_id": "uav_l2_1_v1",
          "waypoints_enu_m": [
            [
              7061.0,
              6197.0,
              34
            ],
            [
              7037.0,
              6184.0,
              31
            ]
          ],
          "velocity_mps": 7.0
        }
      ],
      "log_event": {
        "topic": "evt_L2-1_v1_backup_link_restore",
        "category": "infrastructure",
        "title": "Backup link restores service",
        "severity": "info",
        "overlay": "infrastructure",
        "target_ids": [
          "uav_l2_1_v1",
          "tower_l2_1_v1"
        ]
      }
    }
  ]
}
