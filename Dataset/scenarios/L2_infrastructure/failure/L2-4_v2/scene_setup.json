      "rule": "semantic_event_contract",
      "contract": {
        "schema": "low_altitude_event_chain_contract_v1",
        "scenario_id": "L2-4_v2",
        "exact_counts": {
          "uav": 3,
          "vehicle": 2,
          "pedestrian": 2,
          "facility": 3,
          "logical": 8
        },
        "inspect": {
          "role": "U_inspect",
          "altitude_code": "I18",
          "altitude_m": 18.0,
          "min_path_length_m": 80.0,
          "required_presence": "episode_full_duration",
          "motion_policy": "inspect_orbit_or_racetrack_not_static_hover"
        },
        "required_event": "pad contention > priority landing",
        "background_semantics": {
          "vehicle_role": "service-road flow",
          "pedestrian_role": "ground observers near pad",
          "policy": "semantic_context_not_decoration"
        },
        "weather": "clear",
        "determinism": {
          "fallback": "forbidden",
          "guessing": "forbidden",
          "compatibility_paths": "forbidden"
        }
      },
      "description": "Episode must match the low-altitude semantic event-chain contract exactly after generation"
    },
    {
      "rule": "uav_corridor_contract",
      "target_uav_count": 3,
      "corridor_segment_count": 10,
      "materialized_corridor_scene_count": 8,
      "allow_building_impact": false,
      "description": "UAV waypoints are repaired for building clearance; corridor scene entities are capped by the exact episode logical-sidecar contract"
