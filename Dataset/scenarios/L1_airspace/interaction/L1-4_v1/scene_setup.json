      "rule": "semantic_event_contract",
      "contract": {
        "schema": "low_altitude_event_chain_contract_v1",
        "scenario_id": "L1-4_v1",
        "exact_counts": {
          "uav": 4,
          "vehicle": 2,
          "pedestrian": 2,
          "facility": 4,
          "logical": 15
        },
        "inspect": {
          "role": "U_inspect",
          "altitude_code": "I28",
          "altitude_m": 28.0,
          "min_path_length_m": 80.0,
          "required_presence": "episode_full_duration",
          "motion_policy": "inspect_orbit_or_racetrack_not_static_hover"
        },
        "required_event": "congestion > priority resequence > land",
        "background_semantics": {
          "vehicle_role": "slow background traffic",
          "pedestrian_role": "waiting near facility/pad area",
          "policy": "semantic_context_not_decoration"
        },
        "weather": "clear",
        "determinism": {
          "fallback": "forbidden",
          "guessing": "forbidden",
          "compatibility_paths": "forbidden"
        }
      },
      "description": "Episode must match the low-altitude semantic event-chain contract exactly after generation"
