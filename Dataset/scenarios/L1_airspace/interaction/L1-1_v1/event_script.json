{
  "$schema": "event_script_v1",
  "scenario_id": "L1-1_v1",
  "description": "Geofence boundary approach and RTH",
  "parameters": {
    "approach_tick": 220,
    "conflict_distance_m": 14.0,
    "resolution_tick": 420
  },
  "triggers": [
    {
      "trigger_id": "trig_approach_boundary",
      "type": "tick",
      "tick": 220
    },
    {
      "trigger_id": "trig_boundary_conflict",
      "type": "entity_proximity",
      "entity_a": "uav_l1_1_v1_primary",
      "entity_b": "nfz_l1_1_v1",
      "distance_m": 14.0,
      "operator": "lte",
      "min_true_ticks": 3
    },
    {
      "trigger_id": "trig_after_boundary_conflict",
      "type": "event_fired",
      "event_id": "boundary_conflict"
    }
  ],
  "events": [
    {
      "event_id": "approach_boundary",
      "trigger_ref": "trig_approach_boundary",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_boundary_approach",
          "entity_id": "uav_l1_1_v1_primary",
          "waypoints_enu_m": [
            [
              38.0,
              12.0,
              30
            ],
            [
              53.0,
              20.0,
              30
            ],
            [
              57.0,
              22.0,
              30
            ]
          ],
          "velocity_mps": 8.0
        }
      ],
      "log_event": {
        "topic": "evt_L1-1_v1_approach_boundary",
        "category": "uav_mission",
        "title": "UAV approaches constrained airspace",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_l1_1_v1_primary",
          "nfz_l1_1_v1"
        ]
      }
    },
    {
      "event_id": "boundary_conflict",
      "trigger_ref": "trig_boundary_conflict",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_boundary_avoidance",
          "entity_id": "uav_l1_1_v1_primary",
          "waypoints_enu_m": [
            [
              57.0,
              22.0,
              30
            ],
            [
              51.0,
              26.0,
              34
            ]
          ],
          "velocity_mps": 3.0
        },
        {
          "type": "set_visual_state",
          "action_id": "hover_boundary_hold",
          "entity_id": "uav_l1_1_v1_primary",
          "visual_state": {
            "mode": "hover"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L1-1_v1_boundary_conflict",
        "category": "airspace",
        "title": "Airspace boundary conflict detected",
        "severity": "warning",
        "overlay": "airspace",
        "target_ids": [
          "uav_l1_1_v1_primary",
          "nfz_l1_1_v1"
        ]
      }
    },
    {
      "event_id": "return_safe_airspace",
      "trigger_ref": "trig_after_boundary_conflict",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_boundary_return_safe",
          "entity_id": "uav_l1_1_v1_primary",
          "waypoints_enu_m": [
            [
              51.0,
              26.0,
              34
            ],
            [
              33.0,
              37.0,
              34
            ]
          ],
          "velocity_mps": 9.0
        }
      ],
      "log_event": {
        "topic": "evt_L1-1_v1_return_safe_airspace",
        "category": "uav_mission",
        "title": "UAV returns to safe airspace",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_l1_1_v1_primary",
          "nfz_l1_1_v1"
        ]
      }
    }
  ]
}
