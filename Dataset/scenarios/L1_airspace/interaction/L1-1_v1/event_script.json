{
  "$schema": "event_script_v1",
  "scenario_id": "L1-1_v1",
  "description": "Geofence boundary approach and RTH",
  "parameters": {
    "approach_tick": 220,
    "conflict_distance_m": 14.0,
    "resolution_tick": 420
  },
  "triggers": [
    {
      "trigger_id": "trig_approach_boundary",
      "type": "tick",
      "tick": 220
    },
    {
      "trigger_id": "trig_boundary_conflict",
      "type": "entity_proximity",
      "entity_a": "uav_l1_1_v1_primary",
      "entity_b": "nfz_l1_1_v1",
      "distance_m": 14.0,
      "operator": "lte",
      "metric": "3d",
      "min_true_ticks": 3
    },
    {
      "trigger_id": "trig_after_boundary_conflict_delay_30",
      "type": "event_fired_after",
      "event_id": "boundary_conflict",
      "delay_ticks": 30
    }
  ],
  "events": [
    {
      "event_id": "approach_boundary",
      "trigger_ref": "trig_approach_boundary",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_boundary_approach",
          "entity_id": "uav_l1_1_v1_primary",
          "waypoints_enu_m": [
            [
              7038.0,
              6212.0,
              30
            ],
            [
              14053.0,
              12420.0,
              30
            ],
            [
              7057.0,
              6222.0,
              30
            ]
          ],
          "velocity_mps": 8.0
        }
      ],
      "log_event": {
        "topic": "evt_L1-1_v1_approach_boundary",
        "category": "uav_mission",
        "title": "UAV approaches constrained airspace",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_l1_1_v1_primary",
          "nfz_l1_1_v1"
        ]
      }
    },
    {
      "event_id": "boundary_conflict",
      "trigger_ref": "trig_boundary_conflict",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_boundary_avoidance",
          "entity_id": "uav_l1_1_v1_primary",
          "waypoints_enu_m": [
            [
              7057.0,
              6222.0,
              30
            ],
            [
              14051.0,
              12426.0,
              34
            ]
          ],
          "velocity_mps": 3.0
        },
        {
          "type": "set_visual_state",
          "action_id": "hover_boundary_hold",
          "entity_id": "uav_l1_1_v1_primary",
          "visual_state": {
            "mode": "hover"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L1-1_v1_boundary_conflict",
        "category": "airspace",
        "title": "Airspace boundary conflict detected",
        "severity": "warning",
        "overlay": "airspace",
        "target_ids": [
          "uav_l1_1_v1_primary",
          "nfz_l1_1_v1"
        ]
      }
    },
    {
      "event_id": "return_safe_airspace",
      "trigger_ref": "trig_after_boundary_conflict_delay_30",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_boundary_return_safe",
          "entity_id": "uav_l1_1_v1_primary",
          "waypoints_enu_m": [
            [
              14051.0,
              12426.0,
              34
            ],
            [
              7033.0,
              6237.0,
              34
            ]
          ],
          "velocity_mps": 9.0
        }
      ],
      "log_event": {
        "topic": "evt_L1-1_v1_return_safe_airspace",
        "category": "uav_mission",
        "title": "UAV returns to safe airspace",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_l1_1_v1_primary",
          "nfz_l1_1_v1"
        ]
      }
    }
  ]
}
