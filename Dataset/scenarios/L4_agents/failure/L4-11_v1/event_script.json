{
  "$schema": "event_script_v1",
  "scenario_id": "L4-11_v1",
  "description": "AV sensor failure, safe stop, and UAV report",
  "parameters": {
    "incident_tick": 260,
    "resolution_tick": 520
  },
  "triggers": [
    {
      "trigger_id": "trig_av_sensor_fault",
      "type": "tick",
      "tick": 230
    },
    {
      "trigger_id": "trig_after_av_sensor_fault_delay_30",
      "type": "event_fired_after",
      "event_id": "av_sensor_fault",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_av_safe_stop_delay_100",
      "type": "event_fired_after",
      "event_id": "av_safe_stop",
      "delay_ticks": 100
    },
    {
      "trigger_id": "trig_after_lane_blockage_report_delay_49",
      "type": "event_fired_after",
      "event_id": "lane_blockage_report",
      "delay_ticks": 49
    }
  ],
  "events": [
    {
      "event_id": "av_sensor_fault",
      "trigger_ref": "trig_av_sensor_fault",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_av_sensor_fault",
          "entity_id": "av_fault_l4_11_v1",
          "visual_state": {
            "mode": "sensor_fault"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L4-11_v1_av_sensor_fault",
        "category": "vehicle",
        "title": "Autonomous vehicle sensor fault detected",
        "severity": "warning",
        "overlay": "vehicle",
        "target_ids": [
          "av_fault_l4_11_v1"
        ]
      }
    },
    {
      "event_id": "av_safe_stop",
      "trigger_ref": "trig_after_av_sensor_fault_delay_30",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_av_safe_stop",
          "entity_id": "av_fault_l4_11_v1",
          "waypoints_enu_m": [
            [
              7147.0,
              6347.0,
              0
            ],
            [
              7158.0,
              6347.6,
              0
            ],
            [
              7165.0,
              6348.0,
              0
            ]
          ],
          "velocity_mps": 2.0
        },
        {
          "type": "set_visual_state",
          "action_id": "set_av_safe_stop",
          "entity_id": "av_fault_l4_11_v1",
          "visual_state": {
            "mode": "safe_stop"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L4-11_v1_av_safe_stop",
        "category": "vehicle",
        "title": "AV performs safe stop in lane",
        "severity": "critical",
        "overlay": "vehicle",
        "target_ids": [
          "av_fault_l4_11_v1"
        ]
      }
    },
    {
      "event_id": "lane_blockage_report",
      "trigger_ref": "trig_after_av_safe_stop_delay_100",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_blockage_report",
          "entity_id": "uav_av_report_l4_11_v1",
          "waypoints_enu_m": [
            [
              7143.0,
              6359.0,
              33
            ],
            [
              7163.0,
              6354.0,
              25
            ]
          ],
          "velocity_mps": 5.0
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_av_lane_blockage",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L4-11_v1_lane_blockage_report",
        "category": "uav_mission",
        "title": "UAV reports lane blockage",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_av_report_l4_11_v1",
          "av_fault_l4_11_v1"
        ]
      }
    },
    {
      "event_id": "av_recovery_hold",
      "trigger_ref": "trig_after_lane_blockage_report_delay_49",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_av_hazard_lights",
          "entity_id": "av_fault_l4_11_v1",
          "visual_state": {
            "mode": "blocked_lane",
            "lights_on": true
          }
        }
      ],
      "log_event": {
        "topic": "evt_L4-11_v1_av_recovery_hold",
        "category": "vehicle",
        "title": "AV remains in safe stop with hazard state",
        "severity": "info",
        "overlay": "vehicle",
        "target_ids": [
          "av_fault_l4_11_v1"
        ]
      }
    }
  ]
}
