{
  "$schema": "event_script_v1",
  "scenario_id": "L4-10_v1",
  "description": "Ambulance priority passage with civilian yield",
  "parameters": {
    "incident_tick": 260,
    "resolution_tick": 520
  },
  "triggers": [
    {
      "trigger_id": "trig_ambulance_priority_approach",
      "type": "tick",
      "tick": 220
    },
    {
      "trigger_id": "trig_after_ambulance_priority_approach",
      "type": "event_fired",
      "event_id": "ambulance_priority_approach"
    },
    {
      "trigger_id": "trig_after_civilian_vehicle_yields",
      "type": "event_fired",
      "event_id": "civilian_vehicle_yields"
    }
  ],
  "events": [
    {
      "event_id": "ambulance_priority_approach",
      "trigger_ref": "trig_ambulance_priority_approach",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_ambulance_lights_on",
          "entity_id": "ambulance_priority_l4_10_v1",
          "visual_state": {
            "mode": "response",
            "lights_on": true
          }
        },
        {
          "type": "move_entity",
          "action_id": "move_ambulance_priority",
          "entity_id": "ambulance_priority_l4_10_v1",
          "waypoints_enu_m": [
            [
              124.0,
              138.0,
              0
            ],
            [
              140.0,
              139.0,
              0
            ],
            [
              164.0,
              141.0,
              0
            ]
          ],
          "velocity_mps": 13.0
        }
      ],
      "log_event": {
        "topic": "evt_L4-10_v1_ambulance_priority_approach",
        "category": "vehicle",
        "title": "Ambulance approaches with lights active",
        "severity": "warning",
        "overlay": "vehicle",
        "target_ids": [
          "ambulance_priority_l4_10_v1",
          "civilian_yield_l4_10_v1"
        ]
      }
    },
    {
