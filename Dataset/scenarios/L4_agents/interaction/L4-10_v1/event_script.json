        {
          "type": "move_entity",
          "action_id": "move_civilian_yield",
          "entity_id": "civilian_yield_l4_10_v1",
          "waypoints_enu_m": [
            [
              146.0,
              140.0,
              0
            ],
            [
              149.0,
              146.0,
              0
            ],
            [
              151.0,
              150.0,
              0
            ]
          ],
          "velocity_mps": 3.0
        }
      ],
      "log_event": {
        "topic": "evt_L4-10_v1_civilian_vehicle_yields",
        "category": "vehicle",
        "title": "Civilian vehicle yields to ambulance",
        "severity": "info",
        "overlay": "vehicle",
        "target_ids": [
          "ambulance_priority_l4_10_v1",
          "civilian_yield_l4_10_v1"
        ]
