{
  "$schema": "event_script_v1",
  "scenario_id": "L4-7_v2",
  "description": "Pedestrian fall detected by UAV and response chain",
  "parameters": {
    "incident_tick": 260,
    "resolution_tick": 520
  },
  "triggers": [
    {
      "trigger_id": "trig_pedestrian_fall",
      "type": "tick",
      "tick": 230
    },
    {
      "trigger_id": "trig_after_pedestrian_fall_delay_30",
      "type": "event_fired_after",
      "event_id": "pedestrian_fall",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_uav_detects_fall_delay_30",
      "type": "event_fired_after",
      "event_id": "uav_detects_fall",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_ambulance_response_delay_30",
      "type": "event_fired_after",
      "event_id": "ambulance_response",
      "delay_ticks": 30
    }
  ],
  "events": [
    {
      "event_id": "pedestrian_fall",
      "trigger_ref": "trig_pedestrian_fall",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "play_animation",
          "action_id": "play_pedestrian_fall",
          "ped_id": "ped_fall_l4_7_v2",
          "animation_path": "/AeroSimHost/Animations/AM_Crouch",
          "start_section": "",
          "play_rate": 1.0,
          "loop_count": 1
        }
      ],
      "log_event": {
        "topic": "evt_L4-7_v2_pedestrian_fall",
        "category": "pedestrian",
        "title": "Pedestrian fall animation starts",
        "severity": "critical",
        "overlay": "pedestrian",
        "target_ids": [
          "ped_fall_l4_7_v2"
        ]
      }
    },
    {
      "event_id": "uav_detects_fall",
      "trigger_ref": "trig_after_pedestrian_fall_delay_30",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_detect_fall",
          "entity_id": "uav_detect_l4_7_v2",
          "waypoints_enu_m": [
            [
              7110.5,
              6319.0,
              31
            ],
            [
              7124.743,
              6334.783,
              16
            ]
          ],
          "velocity_mps": 5.0
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_fall_detection",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L4-7_v2_uav_detects_fall",
        "category": "uav_mission",
        "title": "UAV detects fallen pedestrian",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_detect_l4_7_v2",
          "ped_fall_l4_7_v2"
        ]
      }
    },
    {
      "event_id": "ambulance_response",
      "trigger_ref": "trig_after_uav_detects_fall_delay_30",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_ambulance_to_fall",
          "entity_id": "ambulance_fall_l4_7_v2",
          "waypoints_enu_m": [
            [
              7094.417,
              6304.837,
              0.0
            ],
            [
              7123.513,
              6337.628,
              0.0
            ]
          ],
          "velocity_mps": 12.0
        }
      ],
      "log_event": {
        "topic": "evt_L4-7_v2_ambulance_response",
        "category": "vehicle",
        "title": "Ambulance responds to detected fall",
        "severity": "warning",
        "overlay": "vehicle",
        "target_ids": [
          "ambulance_fall_l4_7_v2",
          "ped_fall_l4_7_v2"
        ]
      }
    },
    {
      "event_id": "incident_documented",
      "trigger_ref": "trig_after_ambulance_response_delay_30",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "capture_screenshot",
          "action_id": "capture_fall_response",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L4-7_v2_incident_documented",
        "category": "uav_mission",
        "title": "UAV documents emergency response",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_detect_l4_7_v2",
          "ambulance_fall_l4_7_v2",
          "ped_fall_l4_7_v2"
        ]
      }
    }
  ]
}
