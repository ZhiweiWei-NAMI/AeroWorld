{
  "$schema": "event_script_v1",
  "scenario_id": "L4-7_v1",
  "description": "Pedestrian fall detected by UAV and response chain",
  "parameters": {
    "incident_tick": 260,
    "resolution_tick": 520
  },
  "triggers": [
    {
      "trigger_id": "trig_pedestrian_fall",
      "type": "tick",
      "tick": 230
    },
    {
      "trigger_id": "trig_after_pedestrian_fall",
      "type": "event_fired",
      "event_id": "pedestrian_fall"
    },
    {
      "trigger_id": "trig_after_uav_detects_fall",
      "type": "event_fired",
      "event_id": "uav_detects_fall"
    },
    {
      "trigger_id": "trig_after_ambulance_response",
      "type": "event_fired",
      "event_id": "ambulance_response"
    }
  ],
  "events": [
    {
      "event_id": "pedestrian_fall",
      "trigger_ref": "trig_pedestrian_fall",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "play_animation",
          "action_id": "play_pedestrian_fall",
          "ped_id": "ped_fall_l4_7_v1",
          "animation_path": "/Game/Animations/Pedestrian/Fall_Flat",
          "start_section": "fall_start",
          "play_rate": 1.0,
          "loop_count": 1
        }
      ],
      "log_event": {
        "topic": "evt_L4-7_v1_pedestrian_fall",
        "category": "pedestrian",
        "title": "Pedestrian fall animation starts",
        "severity": "critical",
        "overlay": "pedestrian",
        "target_ids": [
          "ped_fall_l4_7_v1"
        ]
      }
    },
    {
      "event_id": "uav_detects_fall",
      "trigger_ref": "trig_after_pedestrian_fall",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_detect_fall",
          "entity_id": "uav_detect_l4_7_v1",
          "waypoints_enu_m": [
            [
              105.0,
              116.0,
              31
            ],
            [
              120.0,
              125.0,
              16
            ]
          ],
          "velocity_mps": 5.0
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_fall_detection",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L4-7_v1_uav_detects_fall",
        "category": "uav_mission",
        "title": "UAV detects fallen pedestrian",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_detect_l4_7_v1",
          "ped_fall_l4_7_v1"
        ]
      }
    },
    {
      "event_id": "ambulance_response",
      "trigger_ref": "trig_after_uav_detects_fall",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_ambulance_to_fall",
          "entity_id": "ambulance_fall_l4_7_v1",
          "waypoints_enu_m": [
            [
              87.0,
              106.0,
              0
            ],
            [
              115.0,
              122.0,
              0
            ]
          ],
          "velocity_mps": 12.0
        }
      ],
      "log_event": {
        "topic": "evt_L4-7_v1_ambulance_response",
        "category": "vehicle",
        "title": "Ambulance responds to detected fall",
        "severity": "warning",
        "overlay": "vehicle",
        "target_ids": [
          "ambulance_fall_l4_7_v1",
          "ped_fall_l4_7_v1"
        ]
      }
    },
    {
      "event_id": "incident_documented",
      "trigger_ref": "trig_after_ambulance_response",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "capture_screenshot",
          "action_id": "capture_fall_response",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L4-7_v1_incident_documented",
        "category": "uav_mission",
        "title": "UAV documents emergency response",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_detect_l4_7_v1",
          "ambulance_fall_l4_7_v1",
          "ped_fall_l4_7_v1"
        ]
      }
    }
  ]
}
