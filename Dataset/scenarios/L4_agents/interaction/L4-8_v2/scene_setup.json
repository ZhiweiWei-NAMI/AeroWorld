    },
    {
      "rule": "asset_in_catalog",
      "entity_id": "crowd_anchor_l4_8_v2",
      "logical_asset_id": "semantic.spawn_zone",
      "description": "Asset ID must match Config/LowAltitude/asset_catalog.json"
    },
