{
  "$schema": "event_script_v1",
  "scenario_id": "L6-5_v1",
  "description": "Ground control station intrusion and abnormal UAV behavior",
  "parameters": {
    "anomaly_tick": 240,
    "recovery_tick": 520
  },
  "triggers": [
    {
      "trigger_id": "trig_gcs_intrusion",
      "type": "tick",
      "tick": 240
    },
    {
      "trigger_id": "trig_after_gcs_intrusion_delay_30",
      "type": "event_fired_after",
      "event_id": "gcs_intrusion",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_abnormal_uav_behavior_delay_30",
      "type": "event_fired_after",
      "event_id": "abnormal_uav_behavior",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_command_lockout_delay_71",
      "type": "event_fired_after",
      "event_id": "command_lockout",
      "delay_ticks": 71
    }
  ],
  "events": [
    {
      "event_id": "gcs_intrusion",
      "trigger_ref": "trig_gcs_intrusion",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_gcs_intrusion",
          "entity_id": "gcs_anchor_l6_5_v1",
          "visual_state": {
            "mode": "intrusion_detected"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L6-5_v1_gcs_intrusion",
        "category": "digital_layer",
        "title": "Ground control station intrusion detected",
        "severity": "critical",
        "overlay": "digital_layer",
        "target_ids": [
          "gcs_anchor_l6_5_v1",
          "uav_digital_l6_5_v1"
        ]
      }
    },
    {
      "event_id": "abnormal_uav_behavior",
      "trigger_ref": "trig_after_gcs_intrusion_delay_30",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_intrusion_abnormal",
          "entity_id": "uav_digital_l6_5_v1",
          "waypoints_enu_m": [
            [
              7098.0,
              6421.6,
              32
            ],
            [
              7118.0,
              6409.6,
              32
            ]
          ],
          "velocity_mps": 9.0
        },
        {
          "type": "set_visual_state",
          "action_id": "set_uav_abnormal_commanded",
          "entity_id": "uav_digital_l6_5_v1",
          "visual_state": {
            "mode": "abnormal_command"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L6-5_v1_abnormal_uav_behavior",
        "category": "uav_mission",
        "title": "UAV follows abnormal command path",
        "severity": "critical",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_digital_l6_5_v1",
          "gcs_anchor_l6_5_v1"
        ]
      }
    },
    {
      "event_id": "command_lockout",
      "trigger_ref": "trig_after_abnormal_uav_behavior_delay_30",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_gcs_locked",
          "entity_id": "gcs_anchor_l6_5_v1",
          "visual_state": {
            "mode": "locked_out"
          }
        },
        {
          "type": "move_entity",
          "action_id": "move_uav_command_lock",
          "entity_id": "uav_digital_l6_5_v1",
          "waypoints_enu_m": [
            [
              7118.0,
              6409.6,
              32
            ],
            [
              7101.0,
              6428.6,
              34
            ]
          ],
          "velocity_mps": 4.0
        }
      ],
      "log_event": {
        "topic": "evt_L6-5_v1_command_lockout",
        "category": "digital_layer",
        "title": "Command lockout and safe route intervention",
        "severity": "warning",
        "overlay": "digital_layer",
        "target_ids": [
          "uav_digital_l6_5_v1",
          "gcs_anchor_l6_5_v1"
        ]
      }
    },
    {
      "event_id": "secure_recovery",
      "trigger_ref": "trig_after_command_lockout_delay_71",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_gcs_secure",
          "entity_id": "gcs_anchor_l6_5_v1",
          "visual_state": {
            "mode": "secure"
          }
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_gcs_recovery",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L6-5_v1_secure_recovery",
        "category": "digital_layer",
        "title": "Ground control station secured",
        "severity": "info",
        "overlay": "digital_layer",
        "target_ids": [
          "uav_digital_l6_5_v1",
          "gcs_anchor_l6_5_v1"
        ]
      }
    }
  ]
}
