{
  "$schema": "event_script_v1",
  "scenario_id": "L6-3_v2",
  "description": "GNSS spoofing route hijack with actual offset",
  "parameters": {
    "anomaly_tick": 240,
    "recovery_tick": 520,
    "spoof_offset_min_m": 10.0
  },
  "triggers": [
    {
      "trigger_id": "trig_spoofing_start",
      "type": "tick",
      "tick": 240
    },
    {
      "trigger_id": "trig_after_spoofing_start",
      "type": "event_fired",
      "event_id": "spoofing_start"
    },
    {
      "trigger_id": "trig_after_spoofed_route_offset",
      "type": "event_fired",
      "event_id": "spoofed_route_offset"
    },
    {
      "trigger_id": "trig_after_safety_route_lock",
      "type": "event_fired",
      "event_id": "safety_route_lock"
    }
  ],
  "events": [
    {
      "event_id": "spoofing_start",
      "trigger_ref": "trig_spoofing_start",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_gnss_spoofing_detected",
          "entity_id": "tower_l6_3_v2",
          "visual_state": {
            "mode": "gnss_spoofing"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L6-3_v2_spoofing_start",
        "category": "digital_layer",
        "title": "GNSS spoofing starts",
        "severity": "critical",
        "overlay": "digital_layer",
        "target_ids": [
          "uav_digital_l6_3_v2",
          "tower_l6_3_v2"
        ]
      }
    },
    {
      "event_id": "spoofed_route_offset",
      "trigger_ref": "trig_after_spoofing_start",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_spoofed_offset",
          "entity_id": "uav_digital_l6_3_v2",
          "waypoints_enu_m": [
            [
              74.0,
              212.0,
              32
            ],
            [
              86.0,
              220.0,
              31
            ],
            [
              101.0,
              230.0,
              31
            ]
          ],
          "velocity_mps": 6.0
        }
      ],
      "log_event": {
        "topic": "evt_L6-3_v2_spoofed_route_offset",
        "category": "uav_mission",
        "title": "UAV deviates from planned route by at least 10m",
        "severity": "critical",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_digital_l6_3_v2"
        ]
      }
    },
    {
      "event_id": "safety_route_lock",
      "trigger_ref": "trig_after_spoofed_route_offset",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_uav_nav_lock",
          "entity_id": "uav_digital_l6_3_v2",
          "visual_state": {
            "mode": "navigation_lock"
          }
        },
        {
          "type": "move_entity",
          "action_id": "move_uav_spoof_corrected",
          "entity_id": "uav_digital_l6_3_v2",
          "waypoints_enu_m": [
            [
              101.0,
              230.0,
              31
            ],
            [
              82.0,
              234.0,
              32
            ]
          ],
          "velocity_mps": 4.0
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_spoof_correction",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L6-3_v2_safety_route_lock",
        "category": "digital_layer",
        "title": "Safety mechanism locks route and corrects spoofing",
        "severity": "warning",
        "overlay": "digital_layer",
        "target_ids": [
          "uav_digital_l6_3_v2",
          "tower_l6_3_v2"
        ]
      }
    },
    {
      "event_id": "spoof_recovery",
      "trigger_ref": "trig_after_safety_route_lock",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_tower_gnss_normal",
          "entity_id": "tower_l6_3_v2",
          "visual_state": {
            "mode": "online"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L6-3_v2_spoof_recovery",
        "category": "digital_layer",
        "title": "GNSS spoofing cleared",
        "severity": "info",
        "overlay": "digital_layer",
        "target_ids": [
          "tower_l6_3_v2",
          "uav_digital_l6_3_v2"
        ]
      }
    }
  ]
}
