{
  "$schema": "event_script_v1",
  "scenario_id": "L5-5_v1",
  "description": "High temperature battery derating and shortened range",
  "parameters": {
    "weather_threshold_tick": 260
  },
  "triggers": [
    {
      "trigger_id": "trig_high_temperature_process",
      "type": "tick",
      "tick": 260
    },
    {
      "trigger_id": "trig_after_high_temperature_process",
      "type": "event_fired",
      "event_id": "high_temperature_process"
    },
    {
      "trigger_id": "trig_after_range_shortened",
      "type": "event_fired",
      "event_id": "range_shortened"
    }
  ],
  "events": [
    {
      "event_id": "high_temperature_process",
      "trigger_ref": "trig_high_temperature_process",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_uav_battery_derating",
          "entity_id": "uav_weather_l5_5_v1",
          "visual_state": {
            "mode": "battery_derating"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L5-5_v1_high_temperature_process",
        "category": "environment",
        "title": "High temperature causes battery derating",
        "severity": "warning",
        "overlay": "environment",
        "target_ids": [
          "uav_weather_l5_5_v1"
        ]
      }
    },
    {
      "event_id": "range_shortened",
      "trigger_ref": "trig_after_high_temperature_process",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_shortened_range",
          "entity_id": "uav_weather_l5_5_v1",
          "waypoints_enu_m": [
            [
              94.0,
              174.0,
              32
            ],
            [
              102.0,
              179.0,
              32
            ]
          ],
          "velocity_mps": 4.0
        }
      ],
      "log_event": {
        "topic": "evt_L5-5_v1_range_shortened",
        "category": "uav_mission",
        "title": "UAV range shortens under derating",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_weather_l5_5_v1"
        ]
      }
    },
    {
      "event_id": "thermal_abort",
      "trigger_ref": "trig_after_range_shortened",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_thermal_abort",
          "entity_id": "uav_weather_l5_5_v1",
          "waypoints_enu_m": [
            [
              102.0,
              179.0,
              32
            ],
            [
              89.0,
              183.0,
              31
            ]
          ],
          "velocity_mps": 4.5
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_temperature_abort",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L5-5_v1_thermal_abort",
        "category": "uav_mission",
        "title": "UAV terminates high-temperature mission",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_weather_l5_5_v1"
        ]
      }
    }
  ]
}
