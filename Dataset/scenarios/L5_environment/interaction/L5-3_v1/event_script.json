{
  "$schema": "event_script_v1",
  "scenario_id": "L5-3_v1",
  "description": "Crosswind payload swing and UAV attitude anomaly",
  "parameters": {
    "weather_threshold_tick": 180
  },
  "triggers": [
    {
      "trigger_id": "trig_weather_onset",
      "type": "tick",
      "tick": 210
    },
    {
      "trigger_id": "trig_wind_condition_met",
      "type": "weather_state",
      "parameter": "wind_speed",
      "operator": "gte",
      "value": 12.0,
      "sustain_ticks": 4
    },
    {
      "trigger_id": "trig_after_wind_condition_met_delay_30",
      "type": "event_fired_after",
      "event_id": "wind_condition_met",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_payload_swing_delay_30",
      "type": "event_fired_after",
      "event_id": "payload_swing",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_wind_gust_intensifies_delay_30",
      "type": "event_fired_after",
      "event_id": "wind_gust_intensifies",
      "delay_ticks": 30
    }
  ],
  "events": [
    {
      "event_id": "weather_onset",
      "trigger_ref": "trig_weather_onset",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_wind_onset",
          "profile": "wind",
          "overrides": {
            "wind_speed": 12.5
          }
        }
      ],
      "log_event": {
        "topic": "evt_L5-3_v1_weather_onset",
        "category": "weather",
        "title": "Wind onset is applied before threshold confirmation",
        "severity": "info",
        "overlay": "weather",
        "target_ids": [
          "uav_weather_l5_3_v1",
          "payload_bag_l5_3_v1"
        ]
      }
    },
    {
      "event_id": "wind_condition_met",
      "trigger_ref": "trig_wind_condition_met",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_crosswind",
          "profile": "wind",
          "overrides": {
            "wind_speed": 12.5
          }
        }
      ],
      "log_event": {
        "topic": "evt_L5-3_v1_wind_condition_met",
        "category": "weather",
        "title": "Crosswind threshold reached",
        "severity": "warning",
        "overlay": "weather",
        "target_ids": [
          "uav_weather_l5_3_v1",
          "payload_bag_l5_3_v1"
        ]
      }
    },
    {
      "event_id": "payload_swing",
      "trigger_ref": "trig_after_wind_condition_met_delay_30",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_payload_swing_path",
          "entity_id": "payload_bag_l5_3_v1",
          "waypoints_enu_m": [
            [
              7071.0,
              6364.5,
              28
            ],
            [
              7074.0,
              6360.5,
              27
            ],
            [
              7068.0,
              6368.5,
              29
            ]
          ],
          "velocity_mps": 2.0
        },
        {
          "type": "set_visual_state",
          "action_id": "set_uav_attitude_unstable",
          "entity_id": "uav_weather_l5_3_v1",
          "visual_state": {
            "mode": "attitude_unstable"
          }
        }
      ],
      "log_event": {
        "topic": "evt_L5-3_v1_payload_swing",
        "category": "uav_mission",
        "title": "Payload swings and UAV attitude becomes abnormal",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_weather_l5_3_v1",
          "payload_bag_l5_3_v1"
        ]
      }
    },
    {
      "event_id": "wind_gust_intensifies",
      "trigger_ref": "trig_after_payload_swing_delay_30",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_wind_gust",
          "profile": "wind",
          "overrides": {
            "wind_speed": 18.0
          }
        },
        {
          "type": "move_entity",
          "action_id": "move_uav_wind_hold",
          "entity_id": "uav_weather_l5_3_v1",
          "waypoints_enu_m": [
            [
              7070.0,
              6363.5,
              32
            ],
            [
              7073.0,
              6368.5,
              33
            ]
          ],
          "velocity_mps": 2.0
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_wind_payload",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L5-3_v1_wind_gust_intensifies",
        "category": "weather",
        "title": "Crosswind intensifies into gust",
        "severity": "critical",
        "overlay": "weather",
        "target_ids": [
          "uav_weather_l5_3_v1",
          "payload_bag_l5_3_v1"
        ]
      }
    },
    {
      "event_id": "wind_recovery",
      "trigger_ref": "trig_after_wind_gust_intensifies_delay_30",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_wind_recovery",
          "entity_id": "uav_weather_l5_3_v1",
          "waypoints_enu_m": [
            [
              7073.0,
              6368.5,
              33
            ],
            [
              7062.0,
              6373.5,
              34
            ]
          ],
          "velocity_mps": 5.0
        },
        {
          "type": "set_weather",
          "action_id": "set_wind_recover",
          "profile": "clear",
          "overrides": {
            "wind_speed": 6.0
          }
        }
      ],
      "log_event": {
        "topic": "evt_L5-3_v1_wind_recovery",
        "category": "uav_mission",
        "title": "Wind eases and UAV exits gust corridor",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_weather_l5_3_v1"
        ]
      }
    }
  ]
}
