    "allow_building_impact": false,
    "uav_corridor_segment_count": 4,
    "uav_altitude_layers_m": [
      30.0,
      50.0,
      80.0
    ],
    "uav_assigned_altitudes_m": {
      "uav_weather_l5_2_v1": 50.0
    },
    "uav_lateral_bypass_used": {
      "uav_weather_l5_2_v1": true
