{
  "$schema": "event_script_v1",
  "scenario_id": "L5-2_v1",
  "description": "Sudden fog visual navigation failure",
  "parameters": {
    "weather_threshold_tick": 180
  },
  "triggers": [
    {
      "trigger_id": "trig_fog_condition_met",
      "type": "weather_state",
      "parameter": "fog",
      "operator": "gte",
      "value": 0.5,
      "sustain_ticks": 5
    },
    {
      "trigger_id": "trig_after_fog_condition_met",
      "type": "event_fired",
      "event_id": "fog_condition_met"
    },
    {
      "trigger_id": "trig_after_visual_navigation_failure",
      "type": "event_fired",
      "event_id": "visual_navigation_failure"
    },
    {
      "trigger_id": "trig_after_fog_worsens",
      "type": "event_fired",
      "event_id": "fog_worsens"
    }
  ],
  "events": [
    {
      "event_id": "fog_condition_met",
      "trigger_ref": "trig_fog_condition_met",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_fog_dense",
          "profile": "fog",
          "overrides": {
            "fog": 0.62,
            "visibility_m": 650.0
          }
        }
      ],
      "log_event": {
        "topic": "evt_L5-2_v1_fog_condition_met",
        "category": "weather",
        "title": "Fog threshold reached",
        "severity": "warning",
        "overlay": "weather",
        "target_ids": [
          "uav_weather_l5_2_v1"
        ]
      }
    },
    {
      "event_id": "visual_navigation_failure",
      "trigger_ref": "trig_after_fog_condition_met",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_uav_visual_nav_degraded",
          "entity_id": "uav_weather_l5_2_v1",
          "visual_state": {
            "mode": "visual_nav_degraded"
          }
        },
        {
          "type": "move_entity",
          "action_id": "move_uav_fog_slow_hold",
          "entity_id": "uav_weather_l5_2_v1",
          "waypoints_enu_m": [
            [
              54.0,
              156.5,
              32
            ],
            [
              60.0,
              160.5,
              32
            ]
          ],
          "velocity_mps": 2.5
        }
      ],
      "log_event": {
        "topic": "evt_L5-2_v1_visual_navigation_failure",
        "category": "uav_mission",
        "title": "Visual navigation degrades in fog",
        "severity": "critical",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_weather_l5_2_v1"
        ]
      }
    },
    {
      "event_id": "fog_worsens",
      "trigger_ref": "trig_after_visual_navigation_failure",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_fog_worse_visibility",
          "profile": "fog",
          "overrides": {
            "fog": 0.85,
            "visibility_m": 260.0
          }
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_fog_failure",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L5-2_v1_fog_worsens",
        "category": "weather",
        "title": "Fog worsens and visibility collapses",
        "severity": "critical",
        "overlay": "weather",
        "target_ids": [
          "uav_weather_l5_2_v1"
        ]
      }
    },
    {
      "event_id": "fog_mission_abort",
      "trigger_ref": "trig_after_fog_worsens",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_fog_abort",
          "entity_id": "uav_weather_l5_2_v1",
          "waypoints_enu_m": [
            [
              60.0,
              160.5,
              32
            ],
            [
              46.0,
              168.5,
              34
            ]
          ],
          "velocity_mps": 4.0
        }
      ],
      "log_event": {
        "topic": "evt_L5-2_v1_fog_mission_abort",
        "category": "uav_mission",
        "title": "UAV aborts mission under dense fog",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_weather_l5_2_v1"
        ]
      }
    }
  ]
}
