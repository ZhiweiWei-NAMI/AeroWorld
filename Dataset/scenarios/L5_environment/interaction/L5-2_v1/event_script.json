{
  "$schema": "event_script_v1",
  "scenario_id": "L5-2_v1",
  "description": "Sudden fog visual navigation failure",
  "parameters": {
    "weather_threshold_tick": 180
  },
  "triggers": [
    {
      "trigger_id": "trig_lifecycle_takeoff_uav_weather_l5_2_v1",
      "type": "tick",
      "tick": 30
    },
    {
      "trigger_id": "trig_weather_onset",
      "type": "tick",
      "tick": 190
    },
    {
      "trigger_id": "trig_fog_condition_met",
      "type": "weather_state",
      "parameter": "fog",
      "operator": "gte",
      "value": 0.5,
      "sustain_ticks": 5
    },
    {
      "trigger_id": "trig_after_fog_condition_met_delay_30",
      "type": "event_fired_after",
      "event_id": "fog_condition_met",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_visual_navigation_failure_delay_32",
      "type": "event_fired_after",
      "event_id": "visual_navigation_failure",
      "delay_ticks": 32
    },
    {
      "trigger_id": "trig_after_fog_worsens_delay_30",
      "type": "event_fired_after",
      "event_id": "fog_worsens",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_fog_mission_abort_delay_80",
      "type": "event_fired_after",
      "event_id": "fog_mission_abort",
      "delay_ticks": 80
    }
  ],
  "events": [
    {
      "event_id": "lifecycle_takeoff_uav_weather_l5_2_v1",
      "trigger_ref": "trig_lifecycle_takeoff_uav_weather_l5_2_v1",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_weather_l5_2_v1_takeoff_entry",
          "entity_id": "uav_weather_l5_2_v1",
          "waypoints_enu_m": [
            [
              7064.794,
              6322.63,
              3.0
            ],
            [
              7064.794,
              6322.63,
              24.0
            ],
            [
              7054.0,
              6356.5,
              32
            ]
          ],
          "velocity_mps": 5.0
        }
      ],
      "log_event": {
        "topic": "evt_L5-2_v1_lifecycle_takeoff_uav_weather_l5_2_v1",
        "category": "uav_lifecycle",
        "title": "UAV takes off from visible home pad and enters mission airspace",
        "severity": "info",
        "overlay": "uav_lifecycle",
        "target_ids": [
          "uav_weather_l5_2_v1",
          "pad_home_uav_weather_l5_2_v1"
        ]
      }
    },
    {
      "event_id": "weather_onset",
      "trigger_ref": "trig_weather_onset",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_fog_onset",
          "profile": "fog",
          "overrides": {
            "fog": 0.6,
            "visibility_m": 650.0
          }
        }
      ],
      "log_event": {
        "topic": "evt_L5-2_v1_weather_onset",
        "category": "weather",
        "title": "Fog onset is applied before threshold confirmation",
        "severity": "info",
        "overlay": "weather",
        "target_ids": [
          "uav_weather_l5_2_v1"
        ]
      }
    },
    {
      "event_id": "fog_condition_met",
      "trigger_ref": "trig_fog_condition_met",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_fog_dense",
          "profile": "fog",
          "overrides": {
            "fog": 0.62,
            "visibility_m": 650.0
          }
        }
      ],
      "log_event": {
        "topic": "evt_L5-2_v1_fog_condition_met",
        "category": "weather",
        "title": "Fog threshold reached",
        "severity": "warning",
        "overlay": "weather",
        "target_ids": [
          "uav_weather_l5_2_v1"
        ]
      }
    },
    {
      "event_id": "visual_navigation_failure",
      "trigger_ref": "trig_after_fog_condition_met_delay_30",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_uav_visual_nav_degraded",
          "entity_id": "uav_weather_l5_2_v1",
          "visual_state": {
            "mode": "visual_nav_degraded"
          }
        },
        {
          "type": "move_entity",
          "action_id": "move_uav_fog_slow_hold",
          "entity_id": "uav_weather_l5_2_v1",
          "waypoints_enu_m": [
            [
              7054.0,
              6356.5,
              32
            ],
            [
              7060.0,
              6360.5,
              32
            ]
          ],
          "velocity_mps": 2.5
        }
      ],
      "log_event": {
        "topic": "evt_L5-2_v1_visual_navigation_failure",
        "category": "uav_mission",
        "title": "Visual navigation degrades in fog",
        "severity": "critical",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_weather_l5_2_v1"
        ]
      }
    },
    {
      "event_id": "fog_worsens",
      "trigger_ref": "trig_after_visual_navigation_failure_delay_32",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_fog_worse_visibility",
          "profile": "fog",
          "overrides": {
            "fog": 0.85,
            "visibility_m": 260.0
          }
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_fog_failure",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L5-2_v1_fog_worsens",
        "category": "weather",
        "title": "Fog worsens and visibility collapses",
        "severity": "critical",
        "overlay": "weather",
        "target_ids": [
          "uav_weather_l5_2_v1"
        ]
      }
    },
    {
      "event_id": "fog_mission_abort",
      "trigger_ref": "trig_after_fog_worsens_delay_30",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_fog_abort",
          "entity_id": "uav_weather_l5_2_v1",
          "waypoints_enu_m": [
            [
              7060.0,
              6360.5,
              32
            ],
            [
              7046.0,
              6368.5,
              34
            ]
          ],
          "velocity_mps": 4.0
        }
      ],
      "log_event": {
        "topic": "evt_L5-2_v1_fog_mission_abort",
        "category": "uav_mission",
        "title": "UAV aborts mission under dense fog",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_weather_l5_2_v1"
        ]
      }
    },
    {
      "event_id": "lifecycle_landing_uav_weather_l5_2_v1",
      "trigger_ref": "trig_after_fog_mission_abort_delay_80",
      "priority": 9,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_weather_l5_2_v1_landing_return",
          "entity_id": "uav_weather_l5_2_v1",
          "waypoints_enu_m": [
            [
              7046.0,
              6368.5,
              34.0
            ],
            [
              7064.794,
              6322.63,
              22.0
            ],
            [
              7064.794,
              6322.63,
              3.0
            ]
          ],
          "velocity_mps": 4.0
        }
      ],
      "log_event": {
        "topic": "evt_L5-2_v1_lifecycle_landing_uav_weather_l5_2_v1",
        "category": "uav_lifecycle",
        "title": "UAV returns to the visible home pad and lands after mission resolution",
        "severity": "info",
        "overlay": "uav_lifecycle",
        "target_ids": [
          "uav_weather_l5_2_v1",
          "pad_home_uav_weather_l5_2_v1"
        ]
      }
    }
  ]
}
