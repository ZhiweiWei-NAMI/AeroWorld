{
  "$schema": "event_script_v1",
  "scenario_id": "L5-4_v1",
  "description": "Dusk light shift and camera underexposure",
  "parameters": {
    "weather_threshold_tick": 260
  },
  "triggers": [
    {
      "trigger_id": "trig_dusk_light_shift",
      "type": "tick",
      "tick": 260
    },
    {
      "trigger_id": "trig_after_dusk_light_shift",
      "type": "event_fired",
      "event_id": "dusk_light_shift"
    },
    {
      "trigger_id": "trig_after_infrared_switch",
      "type": "event_fired",
      "event_id": "infrared_switch"
    }
  ],
  "events": [
    {
      "event_id": "dusk_light_shift",
      "trigger_ref": "trig_dusk_light_shift",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_camera_underexposed",
          "entity_id": "uav_weather_l5_4_v1",
          "visual_state": {
            "mode": "camera_underexposed"
          }
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_dusk_underexposure",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L5-4_v1_dusk_light_shift",
        "category": "environment",
        "title": "Dusk light shift underexposes camera",
        "severity": "warning",
        "overlay": "environment",
        "target_ids": [
          "uav_weather_l5_4_v1"
        ]
      }
    },
    {
      "event_id": "infrared_switch",
      "trigger_ref": "trig_after_dusk_light_shift",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_uav_infrared_mode",
          "entity_id": "uav_weather_l5_4_v1",
          "visual_state": {
            "mode": "infrared_navigation"
          }
        },
        {
          "type": "move_entity",
          "action_id": "move_uav_ir_continue",
          "entity_id": "uav_weather_l5_4_v1",
          "waypoints_enu_m": [
            [
              86.0,
              170.5,
              32
            ],
            [
              98.0,
              178.5,
              32
            ]
          ],
          "velocity_mps": 5.0
        }
      ],
      "log_event": {
        "topic": "evt_L5-4_v1_infrared_switch",
        "category": "uav_mission",
        "title": "UAV switches to infrared navigation",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_weather_l5_4_v1"
        ]
      }
    },
    {
      "event_id": "low_light_termination",
      "trigger_ref": "trig_after_infrared_switch",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "capture_screenshot",
          "action_id": "capture_infrared_validation",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_L5-4_v1_low_light_termination",
        "category": "uav_mission",
        "title": "Low-light segment terminates after validation",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_weather_l5_4_v1"
        ]
      }
    }
  ]
}
