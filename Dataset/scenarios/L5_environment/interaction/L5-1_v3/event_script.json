{
  "$schema": "event_script_v1",
  "scenario_id": "L5-1_v3",
  "description": "Rain cascade with UAV and ground traffic slowdown",
  "parameters": {
    "weather_threshold_tick": 180
  },
  "triggers": [
    {
      "trigger_id": "trig_weather_onset",
      "type": "tick",
      "tick": 180
    },
    {
      "trigger_id": "trig_rain_condition_met",
      "type": "weather_state",
      "parameter": "rain",
      "operator": "gte",
      "value": 0.5,
      "sustain_ticks": 5
    },
    {
      "trigger_id": "trig_after_rain_condition_met_delay_30",
      "type": "event_fired_after",
      "event_id": "rain_condition_met",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_rain_speed_reduction_delay_47",
      "type": "event_fired_after",
      "event_id": "rain_speed_reduction",
      "delay_ticks": 47
    },
    {
      "trigger_id": "trig_after_rain_intensifies_delay_30",
      "type": "event_fired_after",
      "event_id": "rain_intensifies",
      "delay_ticks": 30
    }
  ],
  "events": [
    {
      "event_id": "weather_onset",
      "trigger_ref": "trig_weather_onset",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_rain_onset",
          "profile": "rain",
          "overrides": {
            "rain": 0.55,
            "visibility_m": 2200.0
          }
        }
      ],
      "log_event": {
        "topic": "evt_L5-1_v3_weather_onset",
        "category": "weather",
        "title": "Rain onset is applied before threshold confirmation",
        "severity": "info",
        "overlay": "weather",
        "target_ids": [
          "uav_weather_l5_1_v3",
          "weather_car_l5_1_v3"
        ]
      }
    },
    {
      "event_id": "rain_condition_met",
      "trigger_ref": "trig_rain_condition_met",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_rain_moderate",
          "profile": "rain",
          "overrides": {
            "rain": 0.55,
            "visibility_m": 2200.0
          }
        }
      ],
      "log_event": {
        "topic": "evt_L5-1_v3_rain_condition_met",
        "category": "weather",
        "title": "Rain threshold reached",
        "severity": "warning",
        "overlay": "weather",
        "target_ids": [
          "uav_weather_l5_1_v3",
          "weather_car_l5_1_v3"
        ]
      }
    },
    {
      "event_id": "rain_speed_reduction",
      "trigger_ref": "trig_after_rain_condition_met_delay_30",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_rain_slowdown",
          "entity_id": "uav_weather_l5_1_v3",
          "waypoints_enu_m": [
            [
              7046.0,
              6353.0,
              32
            ],
            [
              7056.0,
              6361.0,
              32
            ]
          ],
          "velocity_mps": 3.0
        },
        {
          "type": "move_entity",
          "action_id": "move_car_wet_slowdown",
          "entity_id": "weather_car_l5_1_v3",
          "waypoints_enu_m": [
            [
              7063.537,
              6313.483,
              0.0
            ],
            [
              7071.152,
              6315.833,
              0.0
            ]
          ],
          "velocity_mps": 3.0
        }
      ],
      "log_event": {
        "topic": "evt_L5-1_v3_rain_speed_reduction",
        "category": "uav_mission",
        "title": "UAV and vehicle slow under rain",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_weather_l5_1_v3",
          "weather_car_l5_1_v3"
        ]
      }
    },
    {
      "event_id": "rain_intensifies",
      "trigger_ref": "trig_after_rain_speed_reduction_delay_47",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_rain_heavy_visibility",
          "profile": "rain",
          "overrides": {
            "rain": 0.82,
            "visibility_m": 900.0
          }
        }
      ],
      "log_event": {
        "topic": "evt_L5-1_v3_rain_intensifies",
        "category": "weather",
        "title": "Rain intensifies and visibility drops",
        "severity": "critical",
        "overlay": "weather",
        "target_ids": [
          "uav_weather_l5_1_v3",
          "weather_car_l5_1_v3"
        ]
      }
    },
    {
      "event_id": "rain_recovery",
      "trigger_ref": "trig_after_rain_intensifies_delay_30",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_rain_recover",
          "entity_id": "uav_weather_l5_1_v3",
          "waypoints_enu_m": [
            [
              7056.0,
              6361.0,
              32
            ],
            [
              7040.0,
              6369.0,
              34
            ]
          ],
          "velocity_mps": 5.0
        },
        {
          "type": "set_weather",
          "action_id": "set_rain_recovering",
          "profile": "clear",
          "overrides": {
            "rain": 0.2,
            "visibility_m": 5000.0
          }
        }
      ],
      "log_event": {
        "topic": "evt_L5-1_v3_rain_recovery",
        "category": "weather",
        "title": "Rain recovers and UAV exits degraded area",
        "severity": "info",
        "overlay": "weather",
        "target_ids": [
          "uav_weather_l5_1_v3"
        ]
      }
    }
  ]
}
