{
  "$schema": "event_script_v1",
  "scenario_id": "X3_pedestrian_fall_to_emergency_response",
  "description": "Pedestrian fall to emergency response chain",
  "parameters": {
    "cross_layer": true
  },
  "triggers": [
    {
      "trigger_id": "trig_pedestrian_fall",
      "type": "tick",
      "tick": 220
    },
    {
      "trigger_id": "trig_after_pedestrian_fall_delay_30",
      "type": "event_fired_after",
      "event_id": "pedestrian_fall",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_uav_detection_delay_30",
      "type": "event_fired_after",
      "event_id": "uav_detection",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_ambulance_dispatch_delay_30",
      "type": "event_fired_after",
      "event_id": "ambulance_dispatch",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_isolation_setup_delay_30",
      "type": "event_fired_after",
      "event_id": "isolation_setup",
      "delay_ticks": 30
    }
  ],
  "events": [
    {
      "event_id": "pedestrian_fall",
      "trigger_ref": "trig_pedestrian_fall",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "play_animation",
          "action_id": "play_x3_ped_fall",
          "ped_id": "ped_x3_fall",
          "animation_path": "/AeroSimHost/Animations/AM_Crouch",
          "start_section": "",
          "play_rate": 1.0,
          "loop_count": 1
        }
      ],
      "log_event": {
        "topic": "evt_X3_pedestrian_fall_to_emergency_response_pedestrian_fall",
        "category": "pedestrian",
        "title": "Pedestrian falls",
        "severity": "critical",
        "overlay": "pedestrian",
        "target_ids": [
          "ped_x3_fall"
        ]
      }
    },
    {
      "event_id": "uav_detection",
      "trigger_ref": "trig_after_pedestrian_fall_delay_30",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_x3_uav_detect",
          "entity_id": "uav_x3_detect",
          "waypoints_enu_m": [
            [
              7059.0,
              6450.0,
              32
            ],
            [
              7114.373,
              6426.431,
              16
            ]
          ],
          "velocity_mps": 5.0
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_x3_detection",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_X3_pedestrian_fall_to_emergency_response_uav_detection",
        "category": "uav_mission",
        "title": "UAV detects pedestrian fall",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_x3_detect",
          "ped_x3_fall"
        ]
      }
    },
    {
      "event_id": "ambulance_dispatch",
      "trigger_ref": "trig_after_uav_detection_delay_30",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_x3_ambulance_dispatch",
          "entity_id": "ambulance_x3",
          "waypoints_enu_m": [
            [
              6977.193,
              6406.004,
              0.0
            ],
            [
              7117.119,
              6427.869,
              0.0
            ]
          ],
          "velocity_mps": 12.0
        }
      ],
      "log_event": {
        "topic": "evt_X3_pedestrian_fall_to_emergency_response_ambulance_dispatch",
        "category": "vehicle",
        "title": "Ambulance is dispatched",
        "severity": "warning",
        "overlay": "vehicle",
        "target_ids": [
          "ambulance_x3",
          "ped_x3_fall"
        ]
      }
    },
    {
      "event_id": "isolation_setup",
      "trigger_ref": "trig_after_ambulance_dispatch_delay_30",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "spawn_entity",
          "action_id": "spawn_x3_police_tape",
          "entity_id": "police_tape_x3",
          "asset_id": "prop.incident.police_tape.v1",
          "position_enu_m": [
            7114.107,
            6426.292,
            0.0
          ],
          "rotation_deg": {
            "yaw_deg": 0
          }
        }
      ],
      "log_event": {
        "topic": "evt_X3_pedestrian_fall_to_emergency_response_isolation_setup",
        "category": "dynamic_constraint",
        "title": "Responder sets incident isolation tape",
        "severity": "warning",
        "overlay": "dynamic_constraint",
        "target_ids": [
          "police_tape_x3",
          "ped_x3_fall"
        ]
      }
    },
    {
      "event_id": "emergency_documented",
      "trigger_ref": "trig_after_isolation_setup_delay_30",
      "priority": 5,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "capture_screenshot",
          "action_id": "capture_x3_response",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_X3_pedestrian_fall_to_emergency_response_emergency_documented",
        "category": "uav_mission",
        "title": "Emergency response documented",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_x3_detect",
          "ambulance_x3",
          "ped_x3_fall"
        ]
      }
    }
  ]
}
