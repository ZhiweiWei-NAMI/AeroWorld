    "cross_layer": true,
    "target_uav_count": 1,
    "uav_corridor_policy": "repair_waypoints_then_visualize_corridors_v1",
    "allow_building_impact": false,
    "uav_corridor_segment_count": 3,
    "uav_altitude_layers_m": [
      30.0,
      50.0,
      80.0
    ],
    "uav_assigned_altitudes_m": {
      "uav_x3_detect": 30.0
    },
    "uav_lateral_bypass_used": {
      "uav_x3_detect": true
