{
  "$schema": "event_script_v1",
  "scenario_id": "X2_gnss_spoof_to_geofence_violation",
  "description": "GNSS spoofing to geofence violation chain",
  "parameters": {
    "cross_layer": true
  },
  "triggers": [
    {
      "trigger_id": "trig_spoofing_start",
      "type": "tick",
      "tick": 230
    },
    {
      "trigger_id": "trig_after_spoofing_start_delay_30",
      "type": "event_fired_after",
      "event_id": "spoofing_start",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_geofence_violation",
      "type": "entity_proximity",
      "entity_a": "uav_x2_spoofed",
      "entity_b": "nfz_x2_geofence",
      "distance_m": 10.0,
      "operator": "lte",
      "metric": "3d",
      "min_true_ticks": 2
    },
    {
      "trigger_id": "trig_after_geofence_violation_delay_30",
      "type": "event_fired_after",
      "event_id": "geofence_violation",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_safety_correction_delay_33",
      "type": "event_fired_after",
      "event_id": "safety_correction",
      "delay_ticks": 33
    }
  ],
  "events": [
    {
      "event_id": "spoofing_start",
      "trigger_ref": "trig_spoofing_start",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_x2_spoof_flag",
          "entity_id": "uav_x2_spoofed",
          "visual_state": {
            "mode": "gnss_spoofed"
          }
        }
      ],
      "log_event": {
        "topic": "evt_X2_gnss_spoof_to_geofence_violation_spoofing_start",
        "category": "digital_layer",
        "title": "GNSS spoofing starts",
        "severity": "critical",
        "overlay": "digital_layer",
        "target_ids": [
          "uav_x2_spoofed"
        ]
      }
    },
    {
      "event_id": "trajectory_offset",
      "trigger_ref": "trig_after_spoofing_start_delay_30",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_x2_spoof_offset",
          "entity_id": "uav_x2_spoofed",
          "waypoints_enu_m": [
            [
              7058.0,
              6451.0,
              32
            ],
            [
              7071.0,
              6456.0,
              32
            ],
            [
              7086.0,
              6463.0,
              32
            ]
          ],
          "velocity_mps": 7.0
        }
      ],
      "log_event": {
        "topic": "evt_X2_gnss_spoof_to_geofence_violation_trajectory_offset",
        "category": "uav_mission",
        "title": "Spoofing offsets UAV trajectory",
        "severity": "critical",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_x2_spoofed"
        ]
      }
    },
    {
      "event_id": "geofence_violation",
      "trigger_ref": "trig_geofence_violation",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_x2_geofence_alert",
          "entity_id": "uav_x2_spoofed",
          "visual_state": {
            "mode": "geofence_alert"
          }
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_x2_geofence_violation",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_X2_gnss_spoof_to_geofence_violation_geofence_violation",
        "category": "airspace",
        "title": "Spoofed route approaches NFZ",
        "severity": "critical",
        "overlay": "airspace",
        "target_ids": [
          "uav_x2_spoofed",
          "nfz_x2_geofence"
        ]
      }
    },
    {
      "event_id": "safety_correction",
      "trigger_ref": "trig_after_geofence_violation_delay_30",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_x2_corrected_route",
          "entity_id": "uav_x2_spoofed",
          "waypoints_enu_m": [
            [
              7086.0,
              6463.0,
              32
            ],
            [
              7066.0,
              6475.0,
              34
            ]
          ],
          "velocity_mps": 8.0
        }
      ],
      "log_event": {
        "topic": "evt_X2_gnss_spoof_to_geofence_violation_safety_correction",
        "category": "uav_mission",
        "title": "Safety correction pulls UAV out of NFZ approach",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_x2_spoofed",
          "nfz_x2_geofence"
        ]
      }
    },
    {
      "event_id": "route_recovered",
      "trigger_ref": "trig_after_safety_correction_delay_33",
      "priority": 5,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_x2_nav_restored",
          "entity_id": "uav_x2_spoofed",
          "visual_state": {
            "mode": "mission_recovered"
          }
        }
      ],
      "log_event": {
        "topic": "evt_X2_gnss_spoof_to_geofence_violation_route_recovered",
        "category": "digital_layer",
        "title": "Navigation recovers",
        "severity": "info",
        "overlay": "digital_layer",
        "target_ids": [
          "uav_x2_spoofed"
        ]
      }
    }
  ]
}
