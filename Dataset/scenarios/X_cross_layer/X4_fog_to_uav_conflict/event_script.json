{
  "$schema": "event_script_v1",
  "scenario_id": "X4_fog_to_uav_conflict",
  "description": "Fog to multi-UAV conflict cross-layer chain",
  "parameters": {
    "cross_layer": true
  },
  "triggers": [
    {
      "trigger_id": "trig_lifecycle_takeoff_uav_x4_a",
      "type": "tick",
      "tick": 30
    },
    {
      "trigger_id": "trig_lifecycle_takeoff_uav_x4_b",
      "type": "tick",
      "tick": 38
    },
    {
      "trigger_id": "trig_fog_onset",
      "type": "tick",
      "tick": 180
    },
    {
      "trigger_id": "trig_fog_threshold",
      "type": "weather_state",
      "parameter": "fog",
      "operator": "gte",
      "value": 0.5,
      "sustain_ticks": 5
    },
    {
      "trigger_id": "trig_after_fog_threshold_delay_30",
      "type": "event_fired_after",
      "event_id": "fog_threshold",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_visibility_drop_delay_30",
      "type": "event_fired_after",
      "event_id": "visibility_drop",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_fog_uav_conflict",
      "type": "entity_proximity",
      "entity_a": "uav_x4_a",
      "entity_b": "uav_x4_b",
      "distance_m": 8.0,
      "operator": "lte",
      "metric": "3d",
      "min_true_ticks": 2
    },
    {
      "trigger_id": "trig_after_fog_uav_conflict_delay_30",
      "type": "event_fired_after",
      "event_id": "fog_uav_conflict",
      "delay_ticks": 30
    },
    {
      "trigger_id": "trig_after_fog_conflict_recovered_delay_80",
      "type": "event_fired_after",
      "event_id": "fog_conflict_recovered",
      "delay_ticks": 80
    },
    {
      "trigger_id": "trig_after_fog_conflict_recovered_delay_88",
      "type": "event_fired_after",
      "event_id": "fog_conflict_recovered",
      "delay_ticks": 88
    }
  ],
  "events": [
    {
      "event_id": "lifecycle_takeoff_uav_x4_a",
      "trigger_ref": "trig_lifecycle_takeoff_uav_x4_a",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_x4_a_takeoff_entry",
          "entity_id": "uav_x4_a",
          "waypoints_enu_m": [
            [
              7109.677,
              6423.972,
              3.0
            ],
            [
              7109.677,
              6423.972,
              24.0
            ],
            [
              7072.0,
              6465.0,
              29
            ]
          ],
          "velocity_mps": 5.0
        }
      ],
      "log_event": {
        "topic": "evt_X4_fog_to_uav_conflict_lifecycle_takeoff_uav_x4_a",
        "category": "uav_lifecycle",
        "title": "UAV takes off from visible home pad and enters mission airspace",
        "severity": "info",
        "overlay": "uav_lifecycle",
        "target_ids": [
          "uav_x4_a",
          "pad_home_uav_x4_a"
        ]
      }
    },
    {
      "event_id": "lifecycle_takeoff_uav_x4_b",
      "trigger_ref": "trig_lifecycle_takeoff_uav_x4_b",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_x4_b_takeoff_entry",
          "entity_id": "uav_x4_b",
          "waypoints_enu_m": [
            [
              7123.761,
              6484.113,
              3.0
            ],
            [
              7123.761,
              6484.113,
              24.0
            ],
            [
              7110.0,
              6475.0,
              31
            ]
          ],
          "velocity_mps": 5.0
        }
      ],
      "log_event": {
        "topic": "evt_X4_fog_to_uav_conflict_lifecycle_takeoff_uav_x4_b",
        "category": "uav_lifecycle",
        "title": "UAV takes off from visible home pad and enters mission airspace",
        "severity": "info",
        "overlay": "uav_lifecycle",
        "target_ids": [
          "uav_x4_b",
          "pad_home_uav_x4_b"
        ]
      }
    },
    {
      "event_id": "fog_onset",
      "trigger_ref": "trig_fog_onset",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_x4_fog_onset",
          "profile": "fog",
          "overrides": {
            "fog": 0.62,
            "visibility_m": 700.0
          }
        }
      ],
      "log_event": {
        "topic": "evt_X4_fog_to_uav_conflict_fog_onset",
        "category": "weather",
        "title": "Fog onset is applied before conflict chain",
        "severity": "info",
        "overlay": "weather",
        "target_ids": [
          "uav_x4_a",
          "uav_x4_b"
        ]
      }
    },
    {
      "event_id": "fog_threshold",
      "trigger_ref": "trig_fog_threshold",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_weather",
          "action_id": "set_x4_fog",
          "profile": "fog",
          "overrides": {
            "fog": 0.65,
            "visibility_m": 700.0
          }
        }
      ],
      "log_event": {
        "topic": "evt_X4_fog_to_uav_conflict_fog_threshold",
        "category": "weather",
        "title": "Fog reaches operational threshold",
        "severity": "warning",
        "overlay": "weather",
        "target_ids": [
          "uav_x4_a",
          "uav_x4_b"
        ]
      }
    },
    {
      "event_id": "visibility_drop",
      "trigger_ref": "trig_after_fog_threshold_delay_30",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_x4_uav_a_visual_degraded",
          "entity_id": "uav_x4_a",
          "visual_state": {
            "mode": "visual_degraded"
          }
        },
        {
          "type": "set_visual_state",
          "action_id": "set_x4_uav_b_visual_degraded",
          "entity_id": "uav_x4_b",
          "visual_state": {
            "mode": "visual_degraded"
          }
        }
      ],
      "log_event": {
        "topic": "evt_X4_fog_to_uav_conflict_visibility_drop",
        "category": "weather",
        "title": "Visibility drops for both UAVs",
        "severity": "warning",
        "overlay": "weather",
        "target_ids": [
          "uav_x4_a",
          "uav_x4_b"
        ]
      }
    },
    {
      "event_id": "fog_converging_routes",
      "trigger_ref": "trig_after_visibility_drop_delay_30",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_x4_uav_a_converge",
          "entity_id": "uav_x4_a",
          "waypoints_enu_m": [
            [
              7072.0,
              6465.0,
              29
            ],
            [
              7091.0,
              6470.0,
              30
            ]
          ],
          "velocity_mps": 6.0
        },
        {
          "type": "move_entity",
          "action_id": "move_x4_uav_b_converge",
          "entity_id": "uav_x4_b",
          "waypoints_enu_m": [
            [
              7110.0,
              6475.0,
              31
            ],
            [
              7091.0,
              6470.0,
              30
            ]
          ],
          "velocity_mps": 6.0
        }
      ],
      "log_event": {
        "topic": "evt_X4_fog_to_uav_conflict_fog_converging_routes",
        "category": "uav_mission",
        "title": "Fog causes converging route conflict",
        "severity": "critical",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_x4_a",
          "uav_x4_b"
        ]
      }
    },
    {
      "event_id": "fog_uav_conflict",
      "trigger_ref": "trig_fog_uav_conflict",
      "priority": 4,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "set_visual_state",
          "action_id": "set_x4_uav_a_hover",
          "entity_id": "uav_x4_a",
          "visual_state": {
            "mode": "hover"
          }
        },
        {
          "type": "move_entity",
          "action_id": "move_x4_uav_b_evasion",
          "entity_id": "uav_x4_b",
          "waypoints_enu_m": [
            [
              7091.0,
              6470.0,
              30
            ],
            [
              7104.0,
              6483.0,
              36
            ]
          ],
          "velocity_mps": 8.0
        },
        {
          "type": "capture_screenshot",
          "action_id": "capture_x4_conflict",
          "camera_id": "demo_high_overview"
        }
      ],
      "log_event": {
        "topic": "evt_X4_fog_to_uav_conflict_fog_uav_conflict",
        "category": "uav_mission",
        "title": "UAV proximity conflict under fog",
        "severity": "critical",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_x4_a",
          "uav_x4_b"
        ]
      }
    },
    {
      "event_id": "fog_conflict_recovered",
      "trigger_ref": "trig_after_fog_uav_conflict_delay_30",
      "priority": 5,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_x4_uav_a_resume",
          "entity_id": "uav_x4_a",
          "waypoints_enu_m": [
            [
              7091.0,
              6470.0,
              30
            ],
            [
              7074.0,
              6483.0,
              30
            ]
          ],
          "velocity_mps": 5.5
        }
      ],
      "log_event": {
        "topic": "evt_X4_fog_to_uav_conflict_fog_conflict_recovered",
        "category": "uav_mission",
        "title": "UAVs recover after fog conflict",
        "severity": "info",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_x4_a",
          "uav_x4_b"
        ]
      }
    },
    {
      "event_id": "lifecycle_landing_uav_x4_a",
      "trigger_ref": "trig_after_fog_conflict_recovered_delay_80",
      "priority": 9,
      "max_fire_count": 1,
      "actions": [
        {
          "type": "move_entity",
          "action_id": "move_uav_x4_a_landing_return",
          "entity_id": "uav_x4_a",
          "waypoints_enu_m": [
            [
              7074.0,
