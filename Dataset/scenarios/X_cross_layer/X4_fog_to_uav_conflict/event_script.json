        }
      ],
      "log_event": {
        "topic": "evt_X4_fog_to_uav_conflict_lifecycle_landing_uav_x4_a",
        "category": "uav_lifecycle",
        "title": "UAV returns to the visible home pad and lands after mission resolution",
        "severity": "info",
        "overlay": "uav_lifecycle",
        "target_ids": [
          "uav_x4_a",
          "pad_home_uav_x4_a"
        ]
      }
    },
    {
      "event_id": "lifecycle_landing_uav_x4_b",
      "trigger_ref": "trig_after_fog_conflict_recovered_delay_88",
