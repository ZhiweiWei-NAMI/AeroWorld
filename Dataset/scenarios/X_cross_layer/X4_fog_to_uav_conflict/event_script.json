            ],
            [
              7123.761,
              6484.113,
              22.0
            ],
            [
              7123.761,
              6484.113,
              3.0
            ]
          ],
          "velocity_mps": 4.0
        }
      ],
      "log_event": {
        "topic": "evt_X4_fog_to_uav_conflict_lifecycle_landing_uav_x4_b",
        "category": "uav_lifecycle",
