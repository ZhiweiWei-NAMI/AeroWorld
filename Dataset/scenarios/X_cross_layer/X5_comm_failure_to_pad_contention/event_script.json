{
  "$schema": "event_script_v1",
  "scenario_id": "X5_comm_failure_to_pad_contention",
  "description": "L2-1(station failure) -> L6-1(C2 loss) -> L2-4(pad contention)",
  "parameters": {},
  "triggers": [
    {
      "trigger_id": "trig_station_failure",
      "type": "tick",
      "tick": 350
    },
    {
      "trigger_id": "trig_after_station_failure",
      "type": "event_fired",
      "event_id": "station_failure"
    },
    {
      "trigger_id": "trig_after_uav_lost_link",
      "type": "event_fired",
      "event_id": "uav_lost_link"
    }
  ],
  "events": [
    {
      "event_id": "station_failure",
      "trigger_ref": "trig_station_failure",
      "priority": 1,
      "max_fire_count": 1,
      "actions": [
        {
          "action_id": "a1",
          "type": "set_visual_state",
          "entity_id": "tower_01",
          "visual_state": {
            "mode": "disabled"
          }
        }
      ],
      "log_event": {
        "topic": "evt_X5_comm_failure_to_pad_contention_station_failure",
        "category": "infrastructure",
        "title": "基站故障",
        "severity": "warning",
        "overlay": "infrastructure",
        "target_ids": [
          "tower_01"
        ]
      },
      "on_fire": {
        "emit_events": [
          "uav_lost_link"
        ]
      }
    },
    {
      "event_id": "uav_lost_link",
      "trigger_ref": "trig_after_station_failure",
      "priority": 2,
      "max_fire_count": 1,
      "actions": [
        {
          "action_id": "a2",
          "type": "move_entity",
          "entity_id": "uav_a",
          "waypoints_enu_m": [
            [
              50,
              20,
              30
            ],
            [
              45,
              15,
              20
            ]
          ],
          "velocity_mps": 5.0
        },
        {
          "action_id": "a3",
          "type": "move_entity",
          "entity_id": "uav_b",
          "waypoints_enu_m": [
            [
              55,
              25,
              30
            ],
            [
              45,
              15,
              25
            ]
          ],
          "velocity_mps": 5.0
        }
      ],
      "log_event": {
        "topic": "evt_X5_comm_failure_to_pad_contention_uav_lost_link",
        "category": "uav_mission",
        "title": "C2链路丢失-双机自主返航",
        "severity": "critical",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_a",
          "uav_b"
        ]
      },
      "on_fire": {
        "emit_events": [
          "pad_conflict"
        ]
      }
    },
    {
      "event_id": "pad_conflict",
      "trigger_ref": "trig_after_uav_lost_link",
      "priority": 3,
      "max_fire_count": 1,
      "actions": [
        {
          "action_id": "a4",
          "type": "move_entity",
          "entity_id": "uav_a",
          "waypoints_enu_m": [
            [
              45,
              15,
              20
            ],
            [
              45,
              15,
              0.5
            ]
          ],
          "velocity_mps": 2.0
        },
        {
          "action_id": "a5",
          "type": "move_entity",
          "entity_id": "uav_b",
          "waypoints_enu_m": [
            [
              45,
              15,
              25
            ],
            [
              40,
              12,
              0.5
            ]
          ],
          "velocity_mps": 2.0
        },
        {
          "action_id": "a6",
          "type": "capture_screenshot",
          "camera_id": "demo_overview"
        }
      ],
      "log_event": {
        "topic": "evt_X5_comm_failure_to_pad_contention_pad_conflict",
        "category": "uav_mission",
        "title": "起降平台冲突-优先级仲裁",
        "severity": "warning",
        "overlay": "uav_mission",
        "target_ids": [
          "uav_a",
          "uav_b"
        ]
      }
    }
  ]
}